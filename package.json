{
  "name": "repodog",
  "description": "An command line module for managing repositories and a set of configs for popular tooling.",
  "version": "2.0.32",
  "author": "miami-man",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/badbatch/repodog",
  "repository": {
    "type": "git",
    "url": "https://github.com/badbatch/repodog.git"
  },
  "bugs": "https://github.com/badbatch/repodog/issues",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm run -r build",
    "clean:deps": "pnpm run -r clean:deps && del-cli ./node_modules",
    "clean:dist": "pnpm run -r clean:dist",
    "coverage-generate": "nyc report --reporter=lcov -t coverage --report-dir coverage",
    "coverage-open": "open-cli ./coverage/lcov-report/index.html",
    "cut:changelog": "changelog",
    "format": "prettier . --check",
    "installActivateMise": "sh shellScripts/installActivateMise.sh",
    "jest": "node --require=suppress-experimental-warnings --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "pnpm run /^lint:.*/",
    "lint:code": "eslint .",
    "lint:docs": "markdownlint-cli2 --config \".markdownlint.json\" \"**/*.md\" \"!**/node_modules/**\"",
    "prepare": "husky",
    "repodog": "repodog",
    "syncpack": "syncpack format --check && syncpack lint",
    "test": "del-cli ./coverage && pnpm run jest && pnpm run coverage-generate",
    "type-check": "tsc --noEmit",
    "validate": "pnpm run syncpack && pnpm run validate:babel && pnpm run validate:swc && pnpm run lint && pnpm run format && pnpm run type-check",
    "validate:babel": "COMPILER=babel pnpm run build && COMPILER=babel pnpm run test",
    "validate:swc": "pnpm run build && pnpm run test"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@commitlint/cli": "^21.1.0",
    "@jest/globals": "^30.4.1",
    "@repodog/babel-config": "workspace:*",
    "@repodog/cli": "workspace:*",
    "@repodog/commitlint-config": "workspace:*",
    "@repodog/eslint-config": "workspace:*",
    "@repodog/eslint-config-jest": "workspace:*",
    "@repodog/jest-config": "workspace:*",
    "@repodog/markdownlint-config": "workspace:*",
    "@repodog/prettier-config": "workspace:*",
    "@repodog/rollup-config": "workspace:*",
    "@repodog/swc-config": "workspace:*",
    "@repodog/syncpack-config": "workspace:*",
    "@repodog/ts-config": "workspace:*",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-swc": "^0.4.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "babel-jest": "^30.4.1",
    "core-js": "^3.49.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "generate-changelog": "^1.8.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-environment-node": "^30.4.1",
    "markdownlint-cli2": "^0.22.1",
    "nyc": "^18.0.0",
    "open-cli": "^9.0.0",
    "prettier": "^3.8.4",
    "rollup": "^4.62.2",
    "suppress-experimental-warnings": "^2.0.0",
    "syncpack": "^15.3.2",
    "typescript": "^6.0.3"
  }
}