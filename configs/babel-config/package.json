{
  "name": "@repodog/babel-config",
  "description": "The Repodog Babel config module.",
  "version": "7.0.7",
  "author": "miami-man",
  "license": "MIT",
  "homepage": "https://github.com/badbatch/repodog",
  "repository": {
    "directory": "configs/babel-config",
    "type": "git",
    "url": "https://github.com/badbatch/repodog/configs/babel-config"
  },
  "bugs": "https://github.com/badbatch/repodog/issues",
  "main": "index.mjs",
  "exports": {
    ".": {
      "default": "./index.mjs"
    },
    "./rollup": {
      "default": "./rollup.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@repodog/babel-preset": "workspace:*"
  },
  "peerDependencies": {
    "@babel/core": "<8",
    "@rollup/plugin-babel": "<8"
  },
  "peerDependenciesMeta": {
    "@rollup/plugin-babel": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.7"
  }
